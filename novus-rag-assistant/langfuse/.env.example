# ─────────────────────────────────────────────────────────────────────────────
# Langfuse Self-Hosted — Environment Variables
# Copy this to .env and fill in your own values.
#
# HOW TO GENERATE SECRETS:
#   SALT / NEXTAUTH_SECRET:  python -c "import secrets; print(secrets.token_hex(16))"
#   ENCRYPTION_KEY:          python -c "import secrets; print(secrets.token_hex(32))"
#   Passwords:               python -c "import secrets; print(secrets.token_urlsafe(20))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Langfuse Core ─────────────────────────────────────────────────────────────
# URL where Langfuse web is accessible (keep localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# Security keys — MUST be unique per installation
SALT=<run: python -c "import secrets; print(secrets.token_hex(16))">
ENCRYPTION_KEY=<run: python -c "import secrets; print(secrets.token_hex(32))">
NEXTAUTH_SECRET=<run: python -c "import secrets; print(secrets.token_hex(24))">

# ── Database (Langfuse's own Postgres — NOT the pgvector one) ─────────────────
POSTGRES_PASSWORD=<your-postgres-password>

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=<your-clickhouse-password>

# ── MinIO (S3-compatible blob storage) ───────────────────────────────────────
MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=<your-minio-password>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_AUTH=<your-redis-password>

# ── Auto-seed: pre-creates org, project, admin user, and API keys on first boot
# After first startup, these values become your Langfuse credentials.
LANGFUSE_INIT_USER_EMAIL=admin@novusbank.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=<your-admin-ui-password>

# These become the API keys you put in the RAG project's .env
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-<run: python -c "import secrets; print(secrets.token_hex(12))">
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-<run: python -c "import secrets; print(secrets.token_hex(12))">

# ── Optional ──────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=false

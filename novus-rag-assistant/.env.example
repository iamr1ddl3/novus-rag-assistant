# OPTION A — Self-hosted (recommended for this course)
#   1. cd langfuse/ && docker-compose up -d
#   2. Wait ~2 min, then open http://localhost:3000
#   3. Login: admin@novusbank.local / NovusAdmin2026!
#   4. Keys below are pre-seeded automatically on first boot.
#
LANGFUSE_PUBLIC_KEY=pk-lf-e99afbbe9cf65d214304c137
LANGFUSE_SECRET_KEY=sk-lf-f21a27a6009bdd97dfccf5c0
LANGFUSE_HOST=http://localhost:3000

